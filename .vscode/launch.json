    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: PyShell",
            "type": "debugpy",
            "request": "launch",
            "env": {
                "PYSHELL_CRYPT_KEY": "MyMinimum30CharacterAESKey1234",
                "PYSHELL_HOST": "0.0.0.0",
                "PYSHELL_PORT": "5050",
                "PYSHELL_PROC_TIMEOUT": "1800"
            },
            "program": "${workspaceFolder}/pyshell.py",
            "console": "integratedTerminal"
        },

        {
            "type": "node",
            "request": "launch",
            "name": "Deploy PyShell on a host, open firewall (NFT)",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {"MONKSHU_HOME": "/Users/rvkapoor/Documents/Programs/source/monkshu"},
            "program": "${workspaceFolder}/pyshellclient.js",
            "args": [
                "-h",
                "109.236.83.38",
                "-p",
                "24",
                "-d",
                "109.236.83.38",
                "61488",
                "root",
                "8642e72cf5ac8206f3653db9e2201832cda38d614c0c25acee79f0e3a3e0c414",
                "/root/pyshell",
                "root",
                "root8642e72cf5ac8206f3653db9e2201832cda38d614c0c25acee79f0e3a3e0c414",
                "0.0.0.0",
                "24",
                "1800",
                "kdhostfirewall"
            ]
        },


        {
            "type": "node",
            "request": "launch",
            "name": "Launch JS Client - ls command",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {"MONKSHU_HOME": "/Users/rvkapoor/Documents/Programs/source/monkshu"},
            "program": "${workspaceFolder}/pyshellclient.js",
            "args": [
                "-h",
                "127.0.0.1",
                "-p",
                "5050",
                "-k",
                "MyMinimum30CharacterAESKey1234",
                "-m",
                "ls",
                "-al"
            ]
        },

        {
            "type": "node",
            "request": "launch",
            "name": "Launch JS Client Polling Mode - ls command",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {"MONKSHU_HOME": "/Users/rvkapoor/Documents/Programs/source/monkshu"},
            "program": "${workspaceFolder}/pyshellclient.js",
            "args": [
                "-h",
                "127.0.0.1",
                "-p",
                "5050",
                "-k",
                "MyMinimum30CharacterAESKey1234",
                "-r",
                "500",
                "-m",
                "ls",
                "-al"
            ]
        },

        {
            "type": "node",
            "request": "launch",
            "name": "Launch JS Client - script",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {"MONKSHU_HOME": "/Users/rvkapoor/Documents/Programs/source/monkshu"},
            "program": "${workspaceFolder}/pyshellclient.js",
            "args": [
                "-h",
                "127.0.0.1",
                "-p",
                "5050",
                "-k",
                "MyMinimum30CharacterAESKey1234",
                "-s",
                "${workspaceFolder}/test.sh",
                "ls",
                "/Users/"
            ]
        },

        {
            "type": "node",
            "request": "launch",
            "name": "Launch JS Client Polling Mode - local script",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {"MONKSHU_HOME": "/Users/rvkapoor/Documents/Programs/source/monkshu"},
            "program": "${workspaceFolder}/pyshellclient.js",
            "args": [
                "-h",
                "127.0.0.1",
                "-p",
                "5050",
                "-k",
                "MyMinimum30CharacterAESKey1234",
                "-r",
                "101",
                "-s",
                "${workspaceFolder}/test.sh",
                "ls",
                "/Users/"
            ]
        },

        {
            "type": "node",
            "request": "launch",
            "name": "Launch JS Client Polling Mode - host test script",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {"MONKSHU_HOME": "/Users/rvkapoor/Documents/Programs/source/monkshu"},
            "program": "${workspaceFolder}/pyshellclient.js",
            "args": [
                "-h",
                "109.236.83.38",
                "-p",
                "24",
                "-k",
                "root8642e72cf5ac8206f3653db9e2201832cda38d614c0c25acee79f0e3a3e0c414",
                "-r",
                "500",
                "-s",
                "${workspaceFolder}/test.sh",
                "ls",
                "/Users/"
            ]
        },

        {
            "type": "node",
            "request": "launch",
            "name": "Launch JS Client Polling Mode - addhost script",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {"MONKSHU_HOME": "/Users/rvkapoor/Documents/Programs/source/monkshu"},
            "program": "${workspaceFolder}/pyshellclient.js",
            "args": [
                "-h",
                "109.236.83.38",
                "-p",
                "24",
                "-k",
                "root8642e72cf5ac8206f3653db9e2201832cda38d614c0c25acee79f0e3a3e0c414",
                "-r",
                "500",
                "-s",
                "${workspaceFolder}/test_host.sh"
            ]
        },

        {
            "type": "node",
            "request": "launch",
            "name": "Launch JS Client - health command",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {"MONKSHU_HOME": "/Users/rvkapoor/Documents/Programs/source/monkshu"},
            "program": "${workspaceFolder}/pyshellclient.js",
            "args": [
                "-h",
                "127.0.0.1",
                "-p",
                "5050",
                "-k",
                "MyMinimum30CharacterAESKey1234",
                "-t"
            ]
        }
    ]
}