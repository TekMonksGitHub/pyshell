{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: PyShell",
            "type": "debugpy",
            "request": "launch",
            "env": {
                "PYSHELL_CRYPT_KEY": "MyMinimum30CharacterAESKey1234",
                "PYSHELL_HOST": "0.0.0.0",
                "PYSHELL_PORT": "5050",
                "PYSHELL_PROC_TIMEOUT": "1800"
            },
            "program": "${workspaceFolder}/pyshell.py",
            "console": "integratedTerminal"
        },

        {
            "type": "node",
            "request": "launch",
            "name": "Deploy PyShell on a host, open firewall (NFT)",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {"MONKSHU_HOME": "/Users/rvkapoor/Documents/Programs/source/monkshu"},
            "program": "${workspaceFolder}/pyshellclient.js",
            "args": [
                "-h",
                "109.236.83.38",
                "-p",
                "24",
                "-d",
                "109.236.83.38",
                "62195",
                "root",
                "36f0a37fe15fa8f2deb962504c0c34b91bdb48accd68e117731ea7f62ee7c29d",
                "/root/pyshell",
                "root",
                "root671a0289ac7646814cfc8fa9991d679f2278d9142bc0722706608054e613f571",
                "0.0.0.0",
                "24",
                "1800",
                "kdhostfirewall"
            ]
        },


        {
            "type": "node",
            "request": "launch",
            "name": "Launch JS Client - ls command",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {"MONKSHU_HOME": "/Users/rvkapoor/Documents/Programs/source/monkshu"},
            "program": "${workspaceFolder}/pyshellclient.js",
            "args": [
                "-h",
                "127.0.0.1",
                "-p",
                "5050",
                "-k",
                "MyMinimum30CharacterAESKey1234",
                "-m",
                "ls",
                "-al"
            ]
        },

        {
            "type": "node",
            "request": "launch",
            "name": "Launch JS Client Polling Mode - ls command",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {"MONKSHU_HOME": "/Users/rvkapoor/Documents/Programs/source/monkshu"},
            "program": "${workspaceFolder}/pyshellclient.js",
            "args": [
                "-h",
                "127.0.0.1",
                "-p",
                "5050",
                "-k",
                "MyMinimum30CharacterAESKey1234",
                "-r",
                "500",
                "-m",
                "ls",
                "-al"
            ]
        },

        {
            "type": "node",
            "request": "launch",
            "name": "Launch JS Client - script",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {"MONKSHU_HOME": "/Users/rvkapoor/Documents/Programs/source/monkshu"},
            "program": "${workspaceFolder}/pyshellclient.js",
            "args": [
                "-h",
                "127.0.0.1",
                "-p",
                "5050",
                "-k",
                "MyMinimum30CharacterAESKey1234",
                "-s",
                "${workspaceFolder}/test.sh",
                "ls",
                "/Users/"
            ]
        },

        {
            "type": "node",
            "request": "launch",
            "name": "Launch JS Client Polling Mode - script",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {"MONKSHU_HOME": "/Users/rvkapoor/Documents/Programs/source/monkshu"},
            "program": "${workspaceFolder}/pyshellclient.js",
            "args": [
                "-h",
                "127.0.0.1",
                "-p",
                "5050",
                "-k",
                "MyMinimum30CharacterAESKey1234",
                "-r",
                "500",
                "-s",
                "${workspaceFolder}/test.sh",
                "ls",
                "/Users/"
            ]
        },

        {
            "type": "node",
            "request": "launch",
            "name": "Launch JS Client Polling Mode - host script",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {"MONKSHU_HOME": "/Users/rvkapoor/Documents/Programs/source/monkshu"},
            "program": "${workspaceFolder}/pyshellclient.js",
            "args": [
                "-h",
                "109.236.83.38",
                "-p",
                "24",
                "-k",
                "root671a0289ac7646814cfc8fa9991d679f2278d9142bc0722706608054e613f571",
                "-r",
                "500",
                "-s",
                "${workspaceFolder}/test_host.sh"
            ]
        },

        {
            "type": "node",
            "request": "launch",
            "name": "Launch JS Client - health command",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {"MONKSHU_HOME": "/Users/rvkapoor/Documents/Programs/source/monkshu"},
            "program": "${workspaceFolder}/pyshellclient.js",
            "args": [
                "-h",
                "127.0.0.1",
                "-p",
                "5050",
                "-k",
                "MyMinimum30CharacterAESKey1234",
                "-t"
            ]
        }
    ]
}